# ===========================================
# 放学帮 后端 环境变量配置
# 复制本文件为 .env 并填入你自己的值
# ===========================================

# --- 数据库 ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fangxue

# --- 微信小程序（去微信公众平台 → 开发管理 → 开发设置 获取） ---
WECHAT_APPID=wx你的小程序appid
WECHAT_SECRET=你的小程序secret

# --- JWT 密钥（随机生成 64 位以上字符串） ---
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_random_secret_here_at_least_64_chars

# --- AI 文案生成（可选，未配置则使用 fallback 文案） ---
# 支持 DeepSeek / OpenAI / 任意 OpenAI 兼容接口
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=your_ai_api_key_here
AI_MODEL=deepseek-chat

# --- 定时任务密钥（可选，用于 cron 触发） ---
CRON_SECRET=
